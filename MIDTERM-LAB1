    .na { color: #9e9080; font-style: italic; }
    .platform-badge {
      background: #efe8df;
      padding: 0.2rem 0.7rem;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 500;
      display: inline-block;
      margin: 0.1rem 0.2rem;
      border: 1px solid #cdc0b0;
      white-space: nowrap;
