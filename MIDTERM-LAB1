      background: var(--cream);
      border: 1.5px solid var(--border);
      border-radius: 3px;
      padding: 8px 18px;
      font-family: 'Lora', serif;
      font-size: .85rem;
      cursor: pointer;
      color: var(--ink);
      transition: all .18s;
    }
    .btn-export:hover { background: var(--accent); border-color: var(--accent); color: white; }

    footer {
      text-align: center;
      margin-top: 3rem;
      color: var(--muted);
      font-size: 0.8rem;
      border-top: 1px dashed var(--border);
      padding-top: 1.5rem;
    }
  </style>
