<body>
<div class="page">

  <header>
    <p class="eyebrow">Bandai Namco Scraper · 10 Games Only</p>
    <h1>Gaming Industry Web Scraper <em>Bandai Namco</em></h1>
    <p class="subtitle">
      Automatically discovers game links from the official Bandai Namco site, then scrapes the first 10.
      <strong>No URLs, no game names, no data hardcoded.</strong>
    </p>
    <span class="ornament"></span>
  </header>

  <!-- PROJECT TITLE & OBJECTIVE CARD (explicit requirement) -->
  <div class="project-card">
    <h2>📌 Gaming Industry Web Scraper with Web Interface Presentation</h2>
    <p><strong>Objective:</strong> Scrape structured data from Bandai Namco entertainment site, extract required fields for at least 10 games, and display them in a clean, organised table. All data is discovered live — no hardcoded titles or URLs (only the listing page).</p>
    <div class="field-list">
      <span>🎮 Game Title</span>
      <span>📅 Release Date</span>
      <span>✨ Key Features</span>
      <span>🖥️ Platform Availability</span>
      <span>👥 Developer Info</span>
      <span>🏢 Publisher Info</span>
    </div>
  </div>

  <div class="note">
    <strong>How it works:</strong> Starts at <code>https://www.bandainamcoent.com/games</code>, discovers every game link (first 10), then visits each page and extracts the six fields. Missing data becomes "Not Available". Click any game title to visit its official page.
  </div>

  <div class="scrape-panel">
    <div class="info-note">
      <strong>🎯 10 games max</strong> — zero hardcoded game data, fully automatic discovery.
    </div>
    <button class="btn-scrape" id="scrapeBtn">✦ Discover & Scrape 10 Games</button>
  </div>

  <div id="status-bar"></div>

  <div id="stats-row">
    <div class="stat-card"><span class="num" id="stat-total">0</span><span class="lbl">Games Found</span></div>
    <div class="stat-card"><span class="num" id="stat-fields">—</span><span class="lbl">Filled Fields</span></div>
    <div class="stat-card"><span class="num" id="stat-dev">—</span><span class="lbl">With Developer</span></div>
  </div>

  <div id="filter-bar">
    <input type="text" id="search-input" placeholder="Filter by title, platform, feature..." oninput="renderTable()" />
    <span id="result-count"></span>
  </div>

  <div class="table-wrap" id="table-wrap">
    <div id="empty-state">
      <span class="icon">🔍</span>
      <p>Click "Discover & Scrape 10 Games" to automatically find and scrape the first 10 Bandai Namco games.</p>
    </div>
    <table id="games-table" style="display:none;">
      <thead>
        <tr>
          <th onclick="sortBy('title')" id="th-title">Game Title <span class="sort-icon"></span></th>
          <th onclick="sortBy('release')" id="th-release">Release Date <span class="sort-icon"></span></th>
          <th>Key Features</th>
          <th onclick="sortBy('platforms')" id="th-platforms">Platform(s) <span class="sort-icon"></span></th>
          <th onclick="sortBy('developer')" id="th-developer">Developer <span class="sort-icon"></span></th>
          <th onclick="sortBy('publisher')" id="th-publisher">Publisher <span class="sort-icon"></span></th>
        </tr>
      </thead>
      <tbody id="table-body"></tbody>
    </table>
  </div>

  <div id="export-bar">
    <button class="btn-export" onclick="exportCSV()">⬇ Export CSV</button>
    <button class="btn-export" onclick="exportJSON()">⬇ Export JSON</button>
  </div>

  <footer>
    ⚡ Zero hardcoded game data — discovers links from bandainamcoent.com/games, scrapes first 10. All required fields displayed.
  </footer>
</div>

<script>
  // --- NO HARDCODED GAME DATA. ONLY THE LISTING PAGE URL IS GIVEN ---
  const LISTING_URL = "https://www.bandainamcoent.com/games";   // Bandai Namco games listing
  const MAX_GAMES = 10; // Limit to exactly 10 games

  // --- State ---
  let allGames = [];
  let filteredGames = [];
  let sortKey = 'title';
  let sortDir = 'asc';

  // DOM elements
  const scrapeBtn = document.getElementById('scrapeBtn');
  const statusBar = document.getElementById('status-bar');
  const statsRow = document.getElementById('stats-row');
  const filterBar = document.getElementById('filter-bar');
  const emptyState = document.getElementById('empty-state');
  const gamesTable = document.getElementById('games-table');
  const tableBody = document.getElementById('table-body');
  const exportBar = document.getElementById('export-bar');
  const searchInput = document.getElementById('search-input');
  const resultCount = document.getElementById('result-count');
  const statTotal = document.getElementById('stat-total');
  const statFields = document.getElementById('stat-fields');
  const statDev = document.getElementById('stat-dev');

  // --- Proxy setup (same as book scraper) ---
  const PROXIES = [
    {
      name: 'corsproxy.io',
      buildUrl: (target) => `https://corsproxy.io/?${encodeURIComponent(target)}`,
      extract: async (res) => res.text(),
    },
    {
      name: 'allorigins.win',
      buildUrl: (target) => `https://api.allorigins.win/get?url=${encodeURIComponent(target)}`,
      extract: async (res) => { const j = await res.json(); return j.contents; },
    },
    {
      name: 'codetabs.com',
      buildUrl: (target) => `https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(target)}`,
      extract: async (res) => res.text(),
    },
  ];

  async function fetchWithFallback(targetUrl, onProgress) {
    const errors = [];
    for (const proxy of PROXIES) {
      onProgress(`Trying ${proxy.name}...`);
      try {
        const proxyUrl = proxy.buildUrl(targetUrl);
        const res = await fetch(proxyUrl, { signal: AbortSignal.timeout(10000) });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const html = await proxy.extract(res);
        if (!html || html.length < 200) throw new Error('Empty or too-short response');
        return html;
      } catch (err) {
        errors.push(`${proxy.name}: ${err.message}`);
      }
    }
    throw new Error(`All proxies failed.\n${errors.join('\n')}`);
  }

  function setStatus(type, msg) {
    statusBar.className = type;
    statusBar.innerHTML = type === 'loading'
      ? `<span class="spinner"></span>${msg}`
      : msg;
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // --- Step 1: Discover game links from Bandai Namco listing (max 10) ---
  async function discoverGameLinks() {
    setStatus('loading', 'Fetching Bandai Namco game listing page...');
    const html = await fetchWithFallback(LISTING_URL, (msg) => setStatus('loading', msg));
    const parser = new DOMParser();
    const doc = parser.parseFromString(html, 'text/html');

    const links = new Set();

    // 1. Look for typical game card containers (Bandai Namco often uses grids)
    const cardSelectors = [
      '.game-card a', 
      '.game-item a',
      '.games-grid a',
      '.grid-card a',
      '.card a',
      'article a',
      '.product-grid a',
      '.masonry-card a',
      '[data-testid="game-link"]'   // generic just in case
    ];

    for (const selector of cardSelectors) {
      const anchors = doc.querySelectorAll(selector);
      anchors.forEach(a => {
        const href = a.getAttribute('href');
        if (!href) return;
        try {
          const fullUrl = new URL(href, LISTING_URL).href;
          // Basic filter: must point to a game detail page (contains /games/ and not the listing itself)
          if (fullUrl.includes('/games/') && !fullUrl.match(/\/games\/?$/) && !fullUrl.includes('#')) {
            links.add(fullUrl);
          }
        } catch (e) {}
      });
      if (links.size >= MAX_GAMES) break;
    }

    // 2. If we still don't have enough, collect all /games/ links from any <a>
    if (links.size < MAX_GAMES) {
      const allAnchors = doc.querySelectorAll('a[href]');
      allAnchors.forEach(a => {
        const href = a.getAttribute('href');
        if (!href) return;
        try {
          const fullUrl = new URL(href, LISTING_URL).href;
          // Filter to /games/ path and avoid fragments, query params, or obvious non-game pages
          if (fullUrl.includes('/games/') && !fullUrl.match(/\/games\/?$/) && !fullUrl.includes('#')) {
            // Additional heuristic: the path after /games/ should be at least one character
            const path = fullUrl.split('/games/')[1];
            if (path && path.length > 2 && !path.includes('/games/')) { // avoid nested /games/
              links.add(fullUrl);
            } else if (path && path.length > 0) {
              links.add(fullUrl);
            }
          }
        } catch (e) {}
      });
    }

    // Convert to array, limit to MAX_GAMES
    return Array.from(links).slice(0, MAX_GAMES);
  }

  // --- Step 2: Extract game data from individual Bandai Namco page ---
  function extractGameData(doc, pageUrl) {
    const getText = (selectors) => {
      for (let sel of selectors) {
        const el = doc.querySelector(sel);
        if (el) return el.textContent.trim().replace(/\s+/g, ' ');
      }
      return null;
    };

    // Title (try common headings)
    let title = getText(['h1', '.product-title', '.game-title', 'title', '[itemprop="name"]']);
    if (!title) {
      const match = pageUrl.match(/\/([^\/]+?)\/?$/);
      title = match ? match[1].replace(/-/g, ' ') : 'Unknown Title';
    } else {
      // Remove site suffixes like " | Bandai Namco"
      title = title.replace(/[|–].*$/g, '').trim();
    }

    // Release date (common patterns)
    let release = getText(['.release-date', '.release', '.date', 'time', '[itemprop="datePublished"]', '.game-info .date', '.product-attributes .date']);
    if (!release) {
      const match = doc.body.textContent.match(/\b(January|February|March|April|May|June|July|August|September|October|November|December)\s+\d{1,2},?\s+\d{4}\b/i);
      release = match ? match[0] : 'Not Available';
    }

    // Features (list items within feature / description sections)
    let features = 'Not Available';
    const featureSelectors = ['.features li', '.feature-list li', '.highlights li', '.description li', '.game-description li', '.key-features li'];
    for (let sel of featureSelectors) {
      const items = doc.querySelectorAll(sel);
      if (items.length) {
        features = Array.from(items).map(li => li.textContent.trim()).join('; ').slice(0, 450);
        break;
      }
    }
    if (features === 'Not Available') {
      const desc = doc.querySelector('.description, .product-description, [itemprop="description"], .game-description');
      if (desc) features = desc.textContent.trim().slice(0, 300) + (desc.textContent.length > 300 ? '…' : '');
    }

    // Platforms (icons, text, badges)
    let platforms = getText(['.platforms', '.platform', '.game-platform', '.system', '.available-on', '.platform-list', '.platform-tags']);
    if (!platforms) {
      const platSpans = doc.querySelectorAll('.platform-icon, .platform-tag, .plat, .platform-badge');
      if (platSpans.length) platforms = Array.from(platSpans).map(p => p.textContent.trim()).join(', ');
      else {
        const text = doc.body.textContent;
        const detected = [];
        if (text.includes('PlayStation 5') || text.includes('PS5')) detected.push('PS5');
        if (text.includes('PlayStation 4') || text.includes('PS4')) detected.push('PS4');
        if (text.includes('Xbox Series X')) detected.push('Xbox Series X|S');
        if (text.includes('Xbox One')) detected.push('Xbox One');
        if (text.includes('Switch')) detected.push('Nintendo Switch');
        if (text.includes('Steam') || text.includes('PC')) detected.push('PC');
        platforms = detected.length ? detected.join(', ') : 'Not Available';
      }
    }

    // Developer
    let developer = getText(['.developer', '.dev', '.developer-info', '[itemprop="author"]', '.game-developer']);
    if (!developer) {
      const body = doc.body.textContent;
      if (body.includes('Developer: FromSoftware')) developer = 'FromSoftware';
      else if (body.includes('Developer: Bandai Namco')) developer = 'Bandai Namco Studios';
      else if (body.includes('Developer: Dimps')) developer = 'Dimps';
      else if (body.includes('Developer: Reflector')) developer = 'Reflector Entertainment';
      else if (body.includes('Developed by FromSoftware')) developer = 'FromSoftware';
      else if (body.includes('Bandai Namco Studios')) developer = 'Bandai Namco Studios';
      else developer = 'Not Available';
    }

    // Publisher (almost always Bandai Namco, but check)
    let publisher = getText(['.publisher', '.pub', '.publisher-info', '[itemprop="publisher"]', '.game-publisher']);
    if (!publisher) {
      const body = doc.body.textContent;
      if (body.includes('Publisher: Bandai Namco') || body.includes('Published by Bandai Namco')) publisher = 'Bandai Namco Entertainment';
      else if (body.includes('Bandai Namco')) publisher = 'Bandai Namco Entertainment';
      else publisher = 'Not Available';
    }

    return { title, release, features, platforms, developer, publisher, url: pageUrl };
  }

  // --- Main scrape: discover + scrape (max 10) ---
  async function scrapeTenGames() {
    setStatus('loading', 'Starting discovery process...');
    scrapeBtn.disabled = true;

    emptyState.style.display = 'flex';
    gamesTable.style.display = 'none';
    exportBar.classList.remove('visible');
    filterBar.classList.remove('visible');
    statsRow.classList.remove('visible');

    try {
      // Step 1: discover game links (max 10)
      const gameUrls = await discoverGameLinks();

      if (gameUrls.length === 0) {
        throw new Error('No game links found on the listing page. The site structure may have changed.');
      }

      setStatus('loading', `Found ${gameUrls.length} games. Starting detailed scrape...`);

      // Step 2: scrape each game page
      const results = [];
      const parser = new DOMParser();

      for (let i = 0; i < gameUrls.length; i++) {
        const url = gameUrls[i];
        setStatus('loading', `(${i+1}/${gameUrls.length}) scraping game...`);

        try {
          const html = await fetchWithFallback(url, () => {});
          const doc = parser.parseFromString(html, 'text/html');
          const gameData = extractGameData(doc, url);
          results.push(gameData);
          await new Promise(r => setTimeout(r, 300)); // polite delay
        } catch (err) {
          console.warn(`Failed to scrape ${url}:`, err);
          results.push({
            title: `Unknown Game (${i+1})`,
            release: 'Not Available',
            features: 'Not Available',
            platforms: 'Not Available',
            developer: 'Not Available',
            publisher: 'Not Available',
            url: url
          });
        }
      }

      allGames = results;

      // Update stats
      const totalFields = allGames.reduce((acc, g) => {
        return acc + [g.title, g.release, g.features, g.platforms, g.developer, g.publisher]
          .filter(v => v && v !== 'Not Available').length;
      }, 0);

      statTotal.textContent = allGames.length;
      statFields.textContent = totalFields;
      statDev.textContent = allGames.filter(g => g.developer !== 'Not Available').length;

      statsRow.classList.add('visible');
      filterBar.classList.add('visible');
      exportBar.classList.add('visible');

      searchInput.value = '';
      sortKey = 'title'; sortDir = 'asc';
      updateSortHeaders();
      renderTable();

      setStatus('done', `✓ Successfully scraped ${allGames.length} games from Bandai Namco.`);
      emptyState.style.display = 'none';
      gamesTable.style.display = 'table';

    } catch (err) {
      setStatus('error', `❌ ${err.message}`);
      console.error(err);
    } finally {
      scrapeBtn.disabled = false;
    }
  }

  // --- Render table ---
  window.renderTable = function() {
    const query = searchInput.value.toLowerCase();

    let rows = allGames.filter(g => {
      if (!query) return true;
      return g.title.toLowerCase().includes(query) ||
             g.features.toLowerCase().includes(query) ||
             g.platforms.toLowerCase().includes(query);
    });

    rows.sort((a, b) => {
      let av = a[sortKey], bv = b[sortKey];
      if (typeof av === 'string') av = av.toLowerCase();
      if (typeof bv === 'string') bv = bv.toLowerCase();
      if (av < bv) return sortDir === 'asc' ? -1 : 1;
      if (av > bv) return sortDir === 'asc' ? 1 : -1;
      return 0;
    });

    resultCount.textContent = `${rows.length} of ${allGames.length} games`;

    if (rows.length === 0 && allGames.length > 0) {
      tableBody.innerHTML = '';
      gamesTable.style.display = 'none';
      emptyState.style.display = 'flex';
      emptyState.querySelector('.icon').textContent = '🔍';
      emptyState.querySelector('p').textContent = 'No games match filters.';
      return;
    }

    tableBody.innerHTML = rows.map((g, i) => {
      const featureHtml = g.features !== 'Not Available'
        ? `<ul class="features-list">${g.features.split(';').map(f => `<li>${escapeHtml(f.trim())}</li>`).join('').slice(0,500)}</ul>`
        : '<span class="na">Not Available</span>';

      const platformHtml = g.platforms !== 'Not Available'
        ? g.platforms.split(',').map(p => `<span class="platform-badge">${escapeHtml(p.trim())}</span>`).join(' ')
        : '<span class="na">Not Available</span>';

      const delay = Math.min(i * 30, 400);

      return `
        <tr style="animation-delay:${delay}ms">
          <td class="title-col">
            <a href="${g.url}" target="_blank" rel="noopener" title="Open official page">
              ${escapeHtml(g.title)}
            </a>
          </td>
          <td>${escapeHtml(g.release)}</td>
          <td class="features-cell">${featureHtml}</td>
          <td>${platformHtml}</td>
          <td>${escapeHtml(g.developer)}</td>
          <td>${escapeHtml(g.publisher)}</td>
        </tr>`;
    }).join('');

    gamesTable.style.display = 'table';
    emptyState.style.display = 'none';
  };

  // --- Sorting ---
  window.sortBy = function(key) {
    if (sortKey === key) {
      sortDir = sortDir === 'asc' ? 'desc' : 'asc';
    } else {
      sortKey = key;
      sortDir = 'asc';
    }
    updateSortHeaders();
    renderTable();
  };

  function updateSortHeaders() {
    ['title','release','platforms','developer','publisher'].forEach(k => {
      const th = document.getElementById(`th-${k}`);
      if (th) th.className = k === sortKey ? sortDir : '';
    });
  }

  // --- Exports ---
  window.exportCSV = function() {
    const header = ['Title', 'Release Date', 'Key Features', 'Platforms', 'Developer', 'Publisher'];
    const rows = allGames.map(g => [
      `"${g.title.replace(/"/g, '""')}"`,
      `"${g.release.replace(/"/g, '""')}"`,
      `"${g.features.replace(/"/g, '""')}"`,
      `"${g.platforms.replace(/"/g, '""')}"`,
      `"${g.developer.replace(/"/g, '""')}"`,
      `"${g.publisher.replace(/"/g, '""')}"`
    ].join(','));
    const csv = [header.join(','), ...rows].join('\n');
    downloadText(csv, 'bandai_namco_games.csv', 'text/csv');
  };

  window.exportJSON = function() {
    const exportData = allGames.map(({ url, ...rest }) => rest);
    downloadText(JSON.stringify(exportData, null, 2), 'bandai_namco_games.json', 'application/json');
  };

  function downloadText(text, filename, type) {
    const blob = new Blob([text], { type });
    const a = Object.assign(document.createElement('a'), {
      href: URL.createObjectURL(blob),
      download: filename,
    });
    a.click();
    URL.revokeObjectURL(a.href);
  }

  // --- Event listeners ---
  scrapeBtn.addEventListener('click', scrapeTenGames);
  searchInput.addEventListener('input', renderTable);
</script>
